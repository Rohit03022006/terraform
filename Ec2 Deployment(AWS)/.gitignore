# Terraform generated files
.terraform/
*.tfstate
*.tfstate.*
crash.log
.terraform.lock.hcl # Include this file in version control if working in a team

# Variable files that may contain sensitive data
*.tfvars
*.tfvars.json

# Local overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan
*.tfplan.binary

# CLI configuration files
.terraformrc
terraform.rc
